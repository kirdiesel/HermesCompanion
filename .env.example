# tg-companion-bot local configuration template
# Copy this file to .env only after explicit confirmation to prepare a live smoke test.
# Do not commit .env or real tokens.

# BotFather token placeholder only; do not put a real token in this example file.
TG_COMPANION_BOT_TOKEN=TG_COMPANION_BOT_TOKEN_FROM_BOTFATHER

# Keep dry-run enabled until all live-run gates are explicitly accepted.
DRY_RUN=true

# Optional single allowed chat for limited live smoke; leave empty in dry-run.
TG_COMPANION_ALLOWED_CHAT_ID=
